//----------------------------------------------------------------------------
// Module: sm3_compress
// Description: SM3 single-round compression module
// Implements SM3 hash algorithm compression function
//----------------------------------------------------------------------------

module sm3_compress (
    input  wire        clk,
    input  wire        rst,
    input  wire        load_en,
    input  wire        calc_en,
    input  wire        update_v_en,
    input  wire [5:0]  round_cnt,
    input  wire [31:0] w,
    input  wire [31:0] w_prime,
    output wire [255:0] hash_out
);

    //--------------------------------------------------------------------------
    // Internal Registers
    //--------------------------------------------------------------------------
    reg [31:0] A, B, C, D, E, F, G, H;
    reg [31:0] V0, V1, V2, V3, V4, V5, V6, V7;

    //--------------------------------------------------------------------------
    // IV Constants (for initialization)
    //--------------------------------------------------------------------------
    localparam [31:0] IV0 = 32'h7380166f;
    localparam [31:0] IV1 = 32'h4914b2b9;
    localparam [31:0] IV2 = 32'h172442d7;
    localparam [31:0] IV3 = 32'hda8a0600;
    localparam [31:0] IV4 = 32'ha96f30bc;
    localparam [31:0] IV5 = 32'h163138aa;
    localparam [31:0] IV6 = 32'he38dee4d;
    localparam [31:0] IV7 = 32'hb0fb0e4e;

    //--------------------------------------------------------------------------
    // T Constants
    //--------------------------------------------------------------------------
    wire [31:0] T_j;
    assign T_j = (round_cnt < 6'd16) ? 32'h79cc4519 : 32'h7a879d8a;

    //--------------------------------------------------------------------------
    // Helper Functions
    //--------------------------------------------------------------------------

    // Rotate Left function
    function [31:0] rol;
        input [31:0] x;
        input [4:0]  n;
        begin
            rol = (x << n) | (x >> (32 - n));
        end
    endfunction

    //--------------------------------------------------------------------------
    // Compression Logic
    //--------------------------------------------------------------------------

    wire [31:0] FF_j, GG_j, SS1, SS2, TT1, TT2;

    // FF_j function
    wire [31:0] FF_small, FF_large;
    assign FF_small = A ^ B ^ C;
    assign FF_large = (A & B) | (A & C) | (B & C);
    assign FF_j = (round_cnt < 6'd16) ? FF_small : FF_large;

    // GG_j function
    wire [31:0] GG_small, GG_large;
    assign GG_small = E ^ F ^ G;
    assign GG_large = (E & F) | (~E & G);
    assign GG_j = (round_cnt < 6'd16) ? GG_small : GG_large;

    // SS1 = ROL((ROL(A,12) + E + ROL(T_j,j)), 7)
    wire [31:0] rot_A12_val, rot_T_jj_val, ss1_temp;
    assign rot_A12_val = rol(A, 5'd12);
    assign rot_T_jj_val = rol(T_j, round_cnt[4:0]);
    assign ss1_temp = rot_A12_val + E + rot_T_jj_val;
    assign SS1 = rol(ss1_temp, 5'd7);

    // SS2 = SS1 XOR ROL(A,12)
    assign SS2 = SS1 ^ rot_A12_val;

    // TT1 = FF_j + D + SS2 + W'_j
    assign TT1 = FF_j + D + SS2 + w_prime;

    // TT2 = GG_j + H + SS1 + W_j
    assign TT2 = GG_j + H + SS1 + w;

    // P0(X) = X XOR ROL(X,9) XOR ROL(X,17)
    wire [31:0] p0_temp;
    assign p0_temp = TT2 ^ rol(TT2, 5'd9) ^ rol(TT2, 5'd17);

    //--------------------------------------------------------------------------
    // Output Assignment
    //--------------------------------------------------------------------------
    assign hash_out = {V0, V1, V2, V3, V4, V5, V6, V7};

    //--------------------------------------------------------------------------
    // Sequential Logic
    //--------------------------------------------------------------------------
    always @(posedge clk) begin
        if (rst) begin
            // Initialize V and working registers to IV
            A <= IV0;
            B <= IV1;
            C <= IV2;
            D <= IV3;
            E <= IV4;
            F <= IV5;
            G <= IV6;
            H <= IV7;
            V0 <= IV0;
            V1 <= IV1;
            V2 <= IV2;
            V3 <= IV3;
            V4 <= IV4;
            V5 <= IV5;
            V6 <= IV6;
            V7 <= IV7;
        end else begin
            if (load_en) begin
                // Load V to working registers A~H
                A <= V0;
                B <= V1;
                C <= V2;
                D <= V3;
                E <= V4;
                F <= V5;
                G <= V6;
                H <= V7;
            end else if (calc_en) begin
                // Perform single round compression - correct state update order
                // D_new = C, C_new = ROL(B,9), B_new = A, A_new = TT1
                // H_new = G, G_new = ROL(F,又19), F_new = E, E_new = P0(TT2)
                D <= C;
                C <= rol(B, 5'd9);
                B <= A;
                A <= TT1;
                H <= G;
                G <= rol(F, 5'd19);
                F <= E;
                E <= p0_temp;
            end else if (update_v_en) begin
                // Update V = V XOR A~H
                V0 <= V0 ^ A;
                V1 <= V1 ^ B;
                V2 <= V2 ^ C;
                V3 <= V3 ^ D;
                V4 <= V4 ^ E;
                V5 <= V5 ^ F;
                V6 <= V6 ^ G;
                V7 <= V7 ^ H;
            end
        end
    end

endmodule
