# RTL source files (all modules in dependency order)
VERILOG_SOURCES = $(PWD)/../rtl/sm3_core.v \
                  $(PWD)/../rtl/sm3_fsm.v \
                  $(PWD)/../rtl/sm3_w_gen.v \
                  $(PWD)/../rtl/sm3_compress.v

# Top-level module to simulate
TOPLEVEL = sm3_core

# Cocotb Python test module (without .py extension)
MODULE = test_sm3_core

# Simulator: icarus (iverilog)
SIM = icarus

# Icarus Verilog compile arguments
# -g2005 enables Verilog-2005 features
# -Wall enables all warnings
COMPILE_ARGS = -g2005 -Wall

# Simulation arguments
# Use basic VCD (fst not supported in this iverilog build)
SIM_ARGS =

# Include cocotb Makefile infrastructure
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets

.PHONY: clean_vcd
clean_vcd:
	rm -f *.vcd *.fst *.lxt

.PHONY: view
view:
	gtkwave tb_sm3_core.vcd 2>/dev/null || gtkwave dump.fst 2>/dev/null || echo "No waveform file found"

# Verilator-only simulation (no cocotb dependency, uses tb_sm3_core.v)
.PHONY: sim_verilog
sim_verilog:
	iverilog -g2005 -Wall -o simv \
		$(PWD)/../rtl/sm3_core.v \
		$(PWD)/../rtl/sm3_fsm.v \
		$(PWD)/../rtl/sm3_w_gen.v \
		$(PWD)/../rtl/sm3_compress.v \
		$(PWD)/tb_sm3_core.v
	vvp simv
